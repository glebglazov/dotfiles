includes = ["~/private/.config/pop/config.toml"]

projects = [
    { path = "~/.local/share/chezmoi" },
    { path = "~/Dev/*/*" },
    { path = "~/Dev/mixed/obsidian_vaults/*", display_depth = 2 }
]

[integrations]
skills_prefix = ""

[[commands]]
key = "ctrl+o"
label = "dev o"
command = "$SHELL -ic 'dev o'"
exit = true

# [project]
# unread_notifications_enabled = false
#
# [worktree]
# unread_notifications_enabled = false

[dashboard]
# current_pane_always_under_cursor = true
cursor_position = "current_any"
sort_criteria = ["status", "pane_last_active_at", "alphabetical"]

[pane_monitoring]
tcp_server = true
ignore_status_from = ["tmux-global"]
topic_agents = [
    { type = "truncate", set_if = "empty" },
    { type = "agent", model = "ollama:gemma4:e4b", set_if = "empty_or_seed", timeout = 60 }
]

[[worktree.commands]]
key = "ctrl+l"
label = "cleanup"
command = "tmux-branch-cleanup"
exit = true

[[worktree.commands]]
key = "ctrl+a"
label = "new"
command = "tmux-create-worktree"
exit = true
