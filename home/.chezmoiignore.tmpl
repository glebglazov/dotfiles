# SSH
.ssh/known_hosts

# NeoVim
.config/nvim/lazy-lock.json

# Tmux
.config/tmux/plugins

# Ignore machine-specific directories
{{ if not .work -}}
private/Dev/work
{{ end -}}

{{ if not .personal -}}
private/Dev/personal
{{ end -}}

# Google MCP OAuth tokens (derived state, auto-refresh, machine-specific)
.config/google-mcp/work/gcal-token.json
.config/google-mcp/personal/gcal-token.json
.config/google-mcp/work/gmail-token.json
.config/google-mcp/personal/gmail-token.json
