#!/bin/sh

# Reads Claude Code context window JSON from stdin and renders a visual status bar.
# Output: [██████░░░░] 63% (1M, Opus) | 55% left - 2h12m | abc123

jq -r '
  (.context_window.used_percentage // 0) as $p |
  ([[($p / 10 | floor), 10] | min, 0] | max) as $f |
  (10 - $f) as $e |

  # Format context window size
  (if .context_window.context_window_size then
    .context_window.context_window_size as $s |
    if $s >= 1000000 then
      "\($s / 1000000 * 10 | floor / 10)M"
    else
      "\($s / 1000 | floor)k"
    end
  else "?" end) as $ctx_size |

  # Model name (handle both string and object)
  (if .model | type == "object" then .model.display_name // "unknown"
  elif .model then .model
  else "unknown" end) as $model |

  # Format remaining time from epoch
  def fmt_remaining(epoch):
    ((epoch - now) | if . < 0 then 0 else . end) as $s |
    if $s >= 3600 then "\($s / 3600 | floor)h\($s % 3600 / 60 | floor)m"
    elif $s >= 60 then "\($s / 60 | floor)m"
    else "\($s | floor)s"
    end;

  # Format rate limits
  (if .rate_limits.five_hour then
    "\(100 - .rate_limits.five_hour.used_percentage | floor)% left - \(fmt_remaining(.rate_limits.five_hour.resets_at))"
  else null end) as $rl5 |
  ($rl5 // "") as $rate |

  "[\("█" * $f)\("░" * $e)] \($p)% (\($ctx_size), \($model))\(if $rate != "" then " | \($rate)" else "" end) | \(.session_id // "no-session")"
'
