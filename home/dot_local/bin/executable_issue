#!/usr/bin/env ruby
# frozen_string_literal: true

# issue — drive a to-issues manifest (docs/issues/<prd-name>/index.json).
#
# This is the standalone code implementation of the to-issues contract
# documented in the `to-issues` skill (index.json schema, eligibility rule,
# done-condition, commit format). The `/run_one` skill is an independent
# prose implementation of the same contract; neither references the other.
#
# Subcommands:
#   issue pick   <folder> [issue-file]           pick next eligible → "<id>\t<file>\t<path>"
#   issue verify <folder> <issue-file>           exit 0 if acceptance criteria all checked
#   issue commit <folder> <id> success <summary…>
#   issue commit <folder> <id> failed  <reason…> [--tries N]
#   issue status <folder>                        table of issue states
#   issue run-one          <folder> [issue-file] headless: spawn agent, retry, commit
#   issue run-all          <folder>              headless loop until nothing eligible
#   issue run-all-parallel <folder>              headless wave-based worktree runner
#
# Agent selection (run-* only), highest precedence first:
#   --agent-cmd "<cmd>"   use this command prefix verbatim
#   --agent <name>        a built-in preset: claude | opencode | cursor | codex | pi
#   AGENT_CMD env         command prefix (how parallel propagates to worktrees)
#   default               the "claude" preset
# The prompt is appended as a single positional argument, so the command must
# accept the prompt as a trailing arg in a headless/non-interactive mode.
#
# Env: AGENT_CMD (see above), MAX_TRIES (3),
#      TRY_TIMEOUT ("" = unlimited, else passed to timeout(1)),
#      ALLOW_DIRTY (skip clean-tree check), DEFER_MANIFEST (skip manifest+progress,
#      caller merges later), MAX_PARALLEL (4).
#
# Exit: 0 ok · 1 worked-but-failed · 2 nothing eligible · 3 preflight/usage · 130 interrupted

require "json"
require "set"
require "time"
require "fileutils"
require "shellwords"
require "rbconfig"
require "tmpdir"

SELF = File.expand_path(__FILE__)
RUBY_BIN = RbConfig.ruby

# Keep the CLI dependency-free. These methods intentionally return plain text;
# callers can still describe semantic emphasis without requiring runtime gems.
module Text
  module_function

  def red(text) = text
  def dim(text) = text
  def cyan(text) = text
  def yellow(text) = text
  def bold(text) = text
  def green(text) = text
  def blue(text) = text
end

PASTEL = Text

# Built-in agent presets. Each value is the command PREFIX; the issue prompt is
# appended as a single trailing argument (see run_agent_once), so every preset
# must accept the prompt as a positional arg in a non-interactive/headless mode.
# Flags for the non-claude agents are best-effort — override with --agent-cmd if
# your CLI version differs.
AGENT_PRESETS = {
  "claude"   => "claude --dangerously-skip-permissions -p",
  "opencode" => "opencode run",
  "cursor"   => "cursor-agent -p --force",
  "codex"    => "codex exec --dangerously-bypass-approvals-and-sandbox",
  "pi"       => "pi -p" # Mario Zechner's pi; YOLO-by-default, no skip-perms flag needed
}.freeze

MAX_TRIES     = Integer(ENV.fetch("MAX_TRIES", "3"))
TRY_TIMEOUT   = ENV.fetch("TRY_TIMEOUT", "")
ALLOW_DIRTY   = !ENV["ALLOW_DIRTY"].to_s.empty?
DEFER_MANIFEST = !ENV["DEFER_MANIFEST"].to_s.empty?
MAX_PARALLEL  = Integer(ENV.fetch("MAX_PARALLEL", "4"))

# --- interrupt handling -------------------------------------------------------
# Child agents run in their own process groups (pgroup: true). The terminal's
# Ctrl-C reaches only this Ruby process; we forward a single TERM to every live
# child group and exit. One Ctrl-C therefore aborts ALL retries/waves at once —
# the bug the old bash runners had (|| true swallowed the signal, next try ran).
$children = []
$children_lock = Mutex.new

def track(pgid)   = $children_lock.synchronize { $children << pgid }
def untrack(pgid) = $children_lock.synchronize { $children.delete(pgid) }

Signal.trap("INT") do
  # No lock here: traps run on the main thread and locking risks deadlock.
  $children.dup.each do |pg|
    begin
      Process.kill("-TERM", pg)
    rescue Errno::ESRCH, Errno::EPERM
      # already gone
    end
  end
  exit 130
end

# --- small helpers ------------------------------------------------------------
def die(msg)
  warn PASTEL.red("issue: #{msg}")
  exit 3
end

def log(msg)
  warn "#{PASTEL.dim("[#{Time.now.strftime("%H:%M:%S")}]")} #{PASTEL.cyan("issue:")} #{msg}"
end

def ts = Time.now.utc.strftime("%Y-%m-%dT%H:%M:%SZ")

def which(bin)
  ENV.fetch("PATH", "").split(File::PATH_SEPARATOR).each do |dir|
    path = File.join(dir, bin)
    return path if File.executable?(path) && !File.directory?(path)
  end
  nil
end

def git!(*args, **opts)
  system("git", *args, **opts) || die("git #{args.join(" ")} failed")
end

# Pull "--flag value" or "--flag=value" out of argv (mutating it), returning the
# value or nil. Lets global options appear before or after the subcommand.
def extract_opt!(argv, flag)
  if (i = argv.index { |a| a.start_with?("#{flag}=") })
    return argv.delete_at(i).split("=", 2)[1]
  end
  if (i = argv.index(flag))
    argv.delete_at(i)
    return argv.delete_at(i) || die("#{flag} requires a value")
  end
  nil
end

# --- manifest model -----------------------------------------------------------
class Manifest
  attr_reader :folder, :path, :progress

  def initialize(folder)
    @folder = folder
    @path = File.join(folder, "index.json")
    @progress = File.join(folder, "progress.txt")
  end

  def prd_name = File.basename(File.expand_path(folder))

  def data = JSON.parse(File.read(path))

  def issues = data.fetch("issues", [])

  def save(payload)
    tmp = "#{path}.tmp"
    File.write(tmp, "#{JSON.pretty_generate(payload)}\n")
    File.rename(tmp, path)
  end

  def find(id) = issues.find { |i| i["id"] == id }
  def find_by_file(file) = issues.find { |i| i["file"] == file }

  # Contract: eligible = status "open" AND every blocked_by id resolves to a
  # "done" issue. A missing blocker id counts as not-done → not eligible.
  # Ordering: AFK-ready issues come before HITL-ready ones (preserving manifest
  # order within each group) so unattended run-all/parallel never stalls on a
  # HITL issue while an autonomous one is available.
  def eligible
    by_id = issues.to_h { |i| [i["id"], i] }
    ready = issues.select do |i|
      i["status"] == "open" &&
        Array(i["blocked_by"]).all? { |b| by_id[b] && by_id[b]["status"] == "done" }
    end
    afk, hitl = ready.partition { |i| i["type"].to_s.upcase != "HITL" }
    afk + hitl
  end

  def set_status(id, status, failed_after: nil)
    payload = data
    issue = payload.fetch("issues").find { |i| i["id"] == id }
    raise "issue id not in manifest: #{id}" unless issue
    issue["status"] = status
    issue["failed_after"] = failed_after if failed_after
    save(payload)
  end

  def append_progress(lines)
    File.open(progress, "a") do |f|
      Array(lines).each { |l| f.puts(l) }
      f.puts("---")
    end
  end
end

# Contract: an issue is done when every checkbox under "## Acceptance criteria"
# (up to the next ## heading) is checked.
def all_criteria_checked?(issue_path)
  in_section = false
  section_seen = false
  checkbox_seen = false
  File.foreach(issue_path) do |line|
    if line =~ /^## Acceptance criteria\s*$/
      in_section = true
      section_seen = true
      next
    end
    in_section = false if in_section && line =~ /^## /
    next unless in_section && line =~ /^\s*-\s+\[([ xX])\]/

    checkbox_seen = true
    return false if Regexp.last_match(1) == " "
  end
  section_seen && checkbox_seen
end

def split_id(id)
  num, name = id.split("-", 2)
  [num, name || id]
end

# --- commit logic (shared by run-* and the `commit` subcommand) ---------------
def commit_success(m, id, summary, defer: DEFER_MANIFEST)
  summary = "(no summary provided)" if summary.to_s.strip.empty?
  num, name = split_id(id)
  file = m.find(id)&.fetch("file", nil) or die("issue id not in manifest: #{id}")

  unless defer
    m.set_status(id, "done")
    m.append_progress(["#{ts} [#{file}] DONE", summary])
  end
  git!("add", "-A")
  git!("commit", "-m", "[#{m.prd_name} #{num}] #{name}\n\n#{summary}")
end

def commit_failed(m, id, reason, tries, defer: DEFER_MANIFEST)
  reason = "(no reason provided)" if reason.to_s.strip.empty?
  num, name = split_id(id)
  file = m.find(id)&.fetch("file", nil) or die("issue id not in manifest: #{id}")

  return if defer

  m.set_status(id, "failed", failed_after: tries)
  m.append_progress(["#{ts} [#{file}] FAILED (after #{tries} tries)", reason])
  git!("add", "-A")
  # Failed commit may have nothing staged; tolerate that.
  system("git", "commit", "-m", "[#{m.prd_name} #{num}] #{name} — failed after #{tries} tries")
end

# --- preflight ----------------------------------------------------------------
def preflight!(folder)
  File.directory?(folder) or die("not a directory: #{folder}")
  File.file?(File.join(folder, "index.json")) or die("manifest not found: #{folder}/index.json")
  which("git") or die("git not found on PATH")
  system("git", "rev-parse", "--show-toplevel", out: File::NULL, err: File::NULL) or die("not inside a git repo")
  return if ALLOW_DIRTY

  dirty = `git status --porcelain`.strip
  die("working tree not clean (set ALLOW_DIRTY=1 to override)") unless dirty.empty?
end

# --- pick ---------------------------------------------------------------------
# Returns [id, file, path] or nil when nothing is eligible.
def pick_issue(m, force_file = nil)
  if force_file && !force_file.empty?
    file = File.basename(force_file)
    issue = m.find_by_file(file) or die("issue file not in manifest: #{file}")
    id = issue["id"]
  else
    issue = m.eligible.first
    return nil unless issue

    id = issue["id"]
    file = issue["file"]
  end
  path = File.join(m.folder, file)
  File.file?(path) or die("issue markdown missing: #{path}")
  [id, file, path]
end

# --- agent prompt -------------------------------------------------------------
def build_prompt(folder, issue_path)
  <<~PROMPT
    You are implementing the issue at: #{issue_path}

    Read the issue file in full. Read any parent or PRD it references (see the
    "## Parent" section) for context. Implement the work described under
    "What to build" and satisfy every box under "Acceptance criteria".

    Do NOT modify #{folder}/index.json. Do NOT modify other issue files in #{folder}.
    Do NOT make git commits — the runner handles assessment and committing.

    When you have completed the work, print a summary block followed by the
    completion sentinel as the final lines of your output, exactly:

    SUMMARY_START
    <one or more lines describing what you did>
    SUMMARY_END
    TASK_COMPLETE

    If you cannot complete the task (blocked, unclear, missing info, repeated
    failure), instead print as the final line:

    TASK_FAILED: <one-line reason>
  PROMPT
end

def extract_summary(text)
  text[/^SUMMARY_START$\n(.*?)^SUMMARY_END$/m, 1]&.strip
end

# Run the agent once. Streams output to the terminal and captures it.
# Returns the captured output string. Spawns in its own process group so the
# INT trap can kill the whole agent subtree.
def run_agent_once(prompt)
  cmd = $agent_cmd
  unless TRY_TIMEOUT.empty?
    tbin = which("timeout") || which("gtimeout")
    if tbin
      cmd = "#{File.basename(tbin)} #{TRY_TIMEOUT} #{cmd}"
    else
      log(PASTEL.yellow("TRY_TIMEOUT set but no timeout(1) found — running without limit"))
    end
  end

  # Deliver the prompt as a single positional argument ("$1") rather than on
  # stdin — the one delivery method all supported agents accept uniformly. The
  # prompt is a real argv element (not interpolated into the script), so no
  # shell-escaping concerns. stdin is /dev/null so agents never block on input.
  out_r, out_w = IO.pipe
  pid = Process.spawn("bash", "-c", "#{cmd} \"$1\"", "issue-agent", prompt,
                      in: File::NULL, out: out_w, err: %i[child out], pgroup: true)
  pgid = Process.getpgid(pid)
  track(pgid)
  out_w.close

  captured = +""
  out_r.each_line do |line|
    print line
    $stdout.flush
    captured << line
  end
  out_r.close
  Process.wait(pid)
  untrack(pgid)
  captured
end

# Core single-issue cycle. Returns exit code (0/1/2).
def run_one(folder, force_file = nil)
  m = Manifest.new(folder)
  preflight!(folder)

  picked = pick_issue(m, force_file)
  unless picked
    log("no eligible issues")
    return 2
  end
  id, file, path = picked

  started = Process.clock_gettime(Process::CLOCK_MONOTONIC)
  log("working #{path} (id: #{PASTEL.bold(id)})")
  prompt = build_prompt(folder, path)

  last_reason = ""
  MAX_TRIES.times do |i|
    log("try #{i + 1}/#{MAX_TRIES}")
    output = run_agent_once(prompt)
    log("agent finished, assessing…")

    if output =~ /^TASK_COMPLETE$/
      if all_criteria_checked?(path)
        summary = extract_summary(output)
        commit_success(m, id, summary)
        elapsed = (Process.clock_gettime(Process::CLOCK_MONOTONIC) - started).round
        log(PASTEL.green("completed #{id} in #{elapsed}s"))
        return 0
      else
        last_reason = "acceptance criteria not all checked"
        log(PASTEL.yellow("try #{i + 1} failed: #{last_reason}"))
      end
    else
      last_reason = output[/^TASK_FAILED:\s*(.+)$/, 1]&.strip || "(no sentinel emitted)"
      log(PASTEL.yellow("try #{i + 1} failed: #{last_reason}"))
    end
  end

  commit_failed(m, id, last_reason, MAX_TRIES)
  elapsed = (Process.clock_gettime(Process::CLOCK_MONOTONIC) - started).round
  log(PASTEL.red("#{id} exhausted after #{MAX_TRIES} tries (#{elapsed}s)"))
  1
end

# --- run-all ------------------------------------------------------------------
def summarize(m)
  issues = m.issues
  total = issues.size
  done = issues.count { |i| i["status"] == "done" }
  failed = issues.count { |i| i["status"] == "failed" }
  other = total - done - failed
  [total, done, failed, other]
end

def run_all(folder)
  m = Manifest.new(folder)
  preflight!(folder)
  started = Process.clock_gettime(Process::CLOCK_MONOTONIC)
  log("starting — folder: #{folder}")

  iteration = 0
  loop do
    iteration += 1
    log("--- iteration #{iteration} ---")
    rc = run_one(folder)
    case rc
    when 0 then log("iteration #{iteration}: issue completed")
    when 1 then log("iteration #{iteration}: issue failed (recorded)")
    when 2 then log("all eligible issues processed"); break
    else exit rc
    end
  end

  total, done, failed, other = summarize(m)
  elapsed = (Process.clock_gettime(Process::CLOCK_MONOTONIC) - started).round
  log("finished in #{elapsed}s — total=#{total} done=#{done} failed=#{failed} blocked=#{other}")
  done == total ? 0 : 1
end

# --- run-all-parallel ---------------------------------------------------------
# Wave-based. Each wave finds ALL eligible issues. One eligible → run inline on
# the current branch. Many → run each in its own git worktree with
# DEFER_MANIFEST=1 (worktree agents commit code only). Results merge back via
# cherry-pick, then the parent flips status on the main branch — keeping every
# agent off index.json so the manifest never causes a merge conflict. A code
# conflict drops the issue to a sequential retry.
def run_all_parallel(folder)
  m = Manifest.new(folder)
  preflight!(folder)

  repo_root = `git rev-parse --show-toplevel`.strip
  wt_dir = File.join(Dir.tmpdir, "issue-worktrees-#{Process.pid}")
  branch = `git rev-parse --abbrev-ref HEAD`.strip
  started = Process.clock_gettime(Process::CLOCK_MONOTONIC)

  cleanup = lambda do
    if File.directory?(wt_dir)
      Dir.glob(File.join(wt_dir, "issue-*")).each do |wt|
        system("git", "worktree", "remove", "--force", wt, out: File::NULL, err: File::NULL) ||
          FileUtils.rm_rf(wt)
      end
      Dir.rmdir(wt_dir) if File.directory?(wt_dir) && Dir.empty?(wt_dir)
    end
    `git branch --list '_parallel/*'`.each_line do |b|
      system("git", "branch", "-D", b.strip, out: File::NULL, err: File::NULL)
    end
  end
  cleanup.call
  at_exit { cleanup.call }

  wave = 0
  loop do
    eligible = m.eligible
    if eligible.empty?
      log("no eligible issues")
      break
    end

    wave += 1
    wave_start = Process.clock_gettime(Process::CLOCK_MONOTONIC)
    log("wave #{wave} — #{eligible.size} eligible: #{eligible.map { |e| e["id"] }.join(", ")}")

    # Single eligible: run directly, no worktree overhead.
    if eligible.size == 1
      rc = run_one(folder, eligible.first["file"])
      break if rc == 2

      next
    end

    batch = eligible.first(MAX_PARALLEL)
    log("launching #{batch.size} parallel agents")
    FileUtils.mkdir_p(wt_dir)

    results = run_wave(folder, batch, repo_root, wt_dir, branch)

    # Merge in batch order; flip manifest on main after each clean cherry-pick.
    retry_seq = []
    results.each do |r|
      file = r[:file]
      wt_branch = r[:branch]
      ahead = `git log #{Shellwords.escape(branch)}..#{Shellwords.escape(wt_branch)} --oneline 2>/dev/null`.lines.size

      if r[:rc] != 0
        log("#{file} — worker failed (rc=#{r[:rc]}); will retry sequentially")
        retry_seq << file
      elsif ahead.zero?
        log("#{file} — no commits (agent failed or no changes)")
        retry_seq << file
      elsif system("git", "cherry-pick", "#{branch}..#{wt_branch}", "--no-edit",
                   out: File::NULL, err: File::NULL)
        summary = r[:summary]
        summary = "(no summary provided)" if summary.to_s.strip.empty?
        issue = m.find_by_file(file)
        m.set_status(issue["id"], "done")
        m.append_progress(["#{ts} [#{file}] DONE", summary])
        git!("add", "--", m.path, m.progress)
        git!("commit", "--amend", "--no-edit")
        log(PASTEL.green("#{file} merged"))
      else
        log(PASTEL.yellow("merge conflict for #{file} — will retry sequentially"))
        system("git", "cherry-pick", "--abort", out: File::NULL, err: File::NULL)
        retry_seq << file
      end

      system("git", "worktree", "remove", "--force", r[:path], out: File::NULL, err: File::NULL) ||
        FileUtils.rm_rf(r[:path])
      system("git", "branch", "-D", wt_branch, out: File::NULL, err: File::NULL)
    end

    unless retry_seq.empty?
      log("retrying #{retry_seq.size} conflicted/failed issues sequentially")
      retry_seq.each do |file|
        log("sequential retry — #{file}")
        run_one(folder, file)
      end
    end

    elapsed = (Process.clock_gettime(Process::CLOCK_MONOTONIC) - wave_start).round
    log("wave #{wave} completed in #{elapsed}s")
  end

  total, done, failed, other = summarize(m)
  elapsed = (Process.clock_gettime(Process::CLOCK_MONOTONIC) - started).round
  log("finished in #{elapsed}s — total=#{total} done=#{done} failed=#{failed} blocked=#{other}")
  done == total ? 0 : 1
end

# Launch one worktree agent per batch entry concurrently.
# Returns [{file:, branch:, path:, rc:, summary:}, …].
def run_wave(folder, batch, repo_root, wt_dir, branch)
  abs_folder = File.expand_path(folder)
  rel_folder = abs_folder.start_with?("#{repo_root}/") ? abs_folder[(repo_root.size + 1)..] : folder

  results = []
  results_lock = Mutex.new

  threads = batch.map do |issue|
    file = issue["file"]
    num, name = split_id(issue["id"])
    wt_branch = "_parallel/#{num}-#{name}"
    wt_path = File.join(wt_dir, "issue-#{num}-#{name}")

    Thread.new do
      system("git", "branch", "-D", wt_branch, out: File::NULL, err: File::NULL)
      unless system("git", "worktree", "add", "-b", wt_branch, wt_path, "HEAD",
                    out: File::NULL, err: File::NULL)
        log(PASTEL.red("#{file} — worktree creation failed"))
        results_lock.synchronize { results << { file: file, branch: wt_branch, path: wt_path, rc: 99, summary: nil } }
        next
      end

      wt_folder = File.join(wt_path, rel_folder)
      log_path = "#{wt_path}.log"
      # Propagate the resolved agent command so worktree agents use the same
      # --agent / --agent-cmd the parent was invoked with.
      env = { "ALLOW_DIRTY" => "1", "DEFER_MANIFEST" => "1", "TRY_TIMEOUT" => TRY_TIMEOUT, "AGENT_CMD" => $agent_cmd }

      File.open(log_path, "w") do |logf|
        pid = Process.spawn(env, RUBY_BIN, SELF, "run-one", wt_folder, File.join(wt_folder, file),
                            chdir: wt_path, out: logf, err: %i[child out], pgroup: true)
        pgid = Process.getpgid(pid)
        track(pgid)
        Process.wait(pid)
        rc = $?.exitstatus
        untrack(pgid)
        output = File.read(log_path)
        summary = extract_summary(output)
        if rc.zero?
          log(PASTEL.green("#{file} — worker done"))
        else
          log(PASTEL.red("#{file} — worker failed (rc=#{rc})"))
        end
        results_lock.synchronize do
          results << { file: file, branch: wt_branch, path: wt_path, rc: rc, summary: summary }
        end
      end
      File.delete(log_path) if File.exist?(log_path)
    end
  end

  threads.each(&:join)
  # Preserve batch order for deterministic cherry-pick sequencing.
  order = batch.map { |i| i["file"] }
  results.sort_by { |r| order.index(r[:file]) || 0 }
end

# --- status -------------------------------------------------------------------
def cmd_status(folder)
  m = Manifest.new(folder)
  File.file?(m.path) or die("manifest not found: #{m.path}")
  by_id = m.issues.to_h { |i| [i["id"], i] }
  eligible_ids = m.eligible.map { |i| i["id"] }.to_set

  rows = m.issues.map do |i|
    state =
      case i["status"]
      when "done" then PASTEL.green("DONE")
      when "failed" then PASTEL.red("FAILED#{i["failed_after"] ? "(#{i["failed_after"]})" : ""}")
      when "in_progress" then PASTEL.blue("IN_PROG")
      else
        eligible_ids.include?(i["id"]) ? PASTEL.yellow("READY") : PASTEL.red("BLOCKED")
      end
    blockers = Array(i["blocked_by"])
    [state, i["type"].to_s, i["id"], blockers.empty? ? "-" : blockers.join(", ")]
  end

  puts "Issues in #{folder}:"
  widths = %w[STATE TYPE ID BLOCKED_BY].each_index.map do |idx|
    ([%w[STATE TYPE ID BLOCKED_BY][idx].length] + rows.map { |row| row[idx].length }).max
  end
  puts format("%-*s  %-*s  %-*s  %-*s", widths[0], "STATE", widths[1], "TYPE", widths[2], "ID", widths[3], "BLOCKED_BY")
  rows.each do |row|
    puts format("%-*s  %-*s  %-*s  %-*s", widths[0], row[0], widths[1], row[1], widths[2], row[2], widths[3], row[3])
  end
  0
end

# --- CLI dispatch -------------------------------------------------------------
def usage!
  warn <<~USAGE
    usage:
      issue pick   <folder> [issue-file]
      issue verify <folder> <issue-file>
      issue commit <folder> <id> success <summary…>
      issue commit <folder> <id> failed  <reason…> [--tries N]
      issue status <folder>
      issue run-one          <folder> [issue-file]
      issue run-all          <folder>
      issue run-all-parallel <folder>

    run-* options:
      --agent <name>        claude (default) | opencode | cursor | codex | pi
      --agent-cmd "<cmd>"   command prefix, overrides --agent (prompt appended as last arg)
  USAGE
  exit 3
end

# Resolve the agent command before dispatch. Options may appear anywhere in
# ARGV; precedence: --agent-cmd > --agent preset > AGENT_CMD env > claude.
agent_cmd_opt = extract_opt!(ARGV, "--agent-cmd")
agent_name    = extract_opt!(ARGV, "--agent")
$agent_cmd =
  if agent_cmd_opt
    agent_cmd_opt
  elsif agent_name
    AGENT_PRESETS[agent_name] || die("unknown --agent #{agent_name.inspect}; known: #{AGENT_PRESETS.keys.join(", ")}")
  elsif !ENV["AGENT_CMD"].to_s.empty?
    ENV["AGENT_CMD"]
  else
    AGENT_PRESETS.fetch("claude")
  end

cmd = ARGV.shift or usage!

case cmd
when "pick"
  folder = ARGV.shift or usage!
  m = Manifest.new(folder)
  File.file?(m.path) or die("manifest not found: #{m.path}")
  picked = pick_issue(m, ARGV.shift)
  exit 2 unless picked

  id, file, path = picked
  puts "#{id}\t#{file}\t#{path}"

when "verify"
  folder = ARGV.shift or usage!
  issue = ARGV.shift or usage!
  issue_path = issue.include?("/") ? issue : File.join(folder, issue)
  File.file?(issue_path) or die("issue markdown missing: #{issue_path}")
  if all_criteria_checked?(issue_path)
    exit 0
  else
    warn PASTEL.yellow("issue: unchecked acceptance criteria remain in #{File.basename(issue_path)}")
    exit 1
  end

when "commit"
  folder = ARGV.shift or usage!
  id = ARGV.shift or usage!
  mode = ARGV.shift or usage!
  m = Manifest.new(folder)
  File.file?(m.path) or die("manifest not found: #{m.path}")
  case mode
  when "success"
    commit_success(m, id, ARGV.join(" "))
  when "failed"
    tries = MAX_TRIES
    if (idx = ARGV.index("--tries"))
      tries = Integer(ARGV[idx + 1])
      ARGV.delete_at(idx + 1)
      ARGV.delete_at(idx)
    end
    commit_failed(m, id, ARGV.join(" "), tries)
  else
    usage!
  end

when "status"
  folder = ARGV.shift or usage!
  exit cmd_status(folder)

when "run-one"
  folder = ARGV.shift or usage!
  exit run_one(folder, ARGV.shift)

when "run-all"
  folder = ARGV.shift or usage!
  exit run_all(folder)

when "run-all-parallel"
  folder = ARGV.shift or usage!
  exit run_all_parallel(folder)

else
  usage!
end
