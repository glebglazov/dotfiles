#!/usr/bin/env bash
# Apply tmux pane border colors based on macOS light/dark appearance.
# Dark mode keeps the original look (subtle gray border, cyan active border).
# Light mode lifts the inactive border off the beige bg and uses a vivid
# orange active border so the focused pane is unmistakable.
set -euo pipefail

if defaults read -g AppleInterfaceStyle 2>/dev/null | grep -qi dark; then
  border=colour238
  active='fg=colour31,bg=default'
else
  border=colour243
  active='fg=colour208,bg=default,bold'
fi

tmux set -g pane-border-style "fg=${border},bg=default"
tmux set -g pane-active-border-style "${active}"

# Ghostty's light/dark theme switch can leave the cursor color from the
# previous theme while inside tmux. Reset it through tmux passthrough so the
# terminal re-applies its active cursor defaults.
target_client=${1:-}
if [[ -n "$target_client" ]]; then
  pane_tty=$(tmux display-message -p -c "$target_client" '#{pane_tty}' 2>/dev/null || true)
else
  pane_tty=$(tmux display-message -p '#{pane_tty}' 2>/dev/null || true)
fi

if [[ -n "$pane_tty" && -w "$pane_tty" ]]; then
  printf '\033Ptmux;\033\033]112\007\033\\' >"$pane_tty"
fi
