#!/usr/bin/env ruby
# frozen_string_literal: true

# issue-loop: traverse docs/issues/<prd-name>/ and report status or next ready issue
# Usage: issue-loop <prd-name> [--status|--next]

require "pathname"

class Issue
  attr_reader :path, :number, :name, :type, :blockers, :criteria

  def initialize(path)
    @path = Pathname.new(path)
    basename = @path.basename(".md").to_s
    match = basename.match(/^(\d+)-(.+)$/)
    @number = match ? match[1] : ""
    @name = match ? match[2] : basename

    content = File.read(path)

    @type = extract_type(content)
    @blockers = extract_blockers(content)
    @criteria = extract_criteria(content)
  end

  def done?
    !criteria.empty? && criteria.all? { |c| c == "x" }
  end

  def ready?(issues_by_name)
    blockers.all? { |b| issues_by_name[b]&.done? }
  end

  private

  def extract_type(content)
    if content =~ /^##\s*Type\s*\n\s*(HITL|AFK)/i
      $1.upcase
    else
      "AFK"
    end
  end

  def extract_blockers(content)
    section = content[/^##\s*Blocked\s+by\s*\n(.*?)(?=^##\s|\z)/m, 1] || ""
    section
      .lines
      .map(&:strip)
      .reject { |line| line.empty? || line.match?(/None/i) }
      .map { |line| line.sub(/^-\s*/, "").strip }
  end

  def extract_criteria(content)
    content.scan(/^-\s*\[([ x])\]\s/).flatten
  end
end

class IssueLoop
  attr_reader :issues, :by_name, :prd_dir

  def initialize(prd_name)
    @prd_dir = Pathname.new("docs/issues") / prd_name
    unless @prd_dir.directory?
      warn "No issues found at #{@prd_dir}"
      exit 1
    end

    load_issues
  end

  def status
    puts "Issues in #{prd_dir}:"
    puts "-" * 70

    issues.each do |issue|
      state = if issue.done?
        green("DONE")
      elsif issue.ready?(by_name)
        yellow("READY")
      else
        red("BLOCKED")
      end

      blockers_str = issue.blockers.empty? ? "-" : issue.blockers.join(", ")
      puts "#{state.ljust(10)} #{issue.type.ljust(5)} #{issue.path.basename.to_s.ljust(35)} <- #{blockers_str}"
    end
  end

  def next_ready
    ready_afk = issues.find { |i| i.ready?(by_name) && !i.done? && i.type == "AFK" }
    ready = ready_afk || issues.find { |i| i.ready?(by_name) && !i.done? }

    if ready
      puts ready.path
    else
      warn "No ready issues."
      exit 1
    end
  end

  private

  def load_issues
    paths = prd_dir.glob("*.md").sort
    if paths.empty?
      warn "No .md files found in #{prd_dir}"
      exit 1
    end

    @issues = paths.map { |p| Issue.new(p) }

    # Index by name and by full filename for blocker resolution
    @by_name = {}
    @issues.each do |issue|
      @by_name[issue.name] = issue
      @by_name[issue.path.basename(".md").to_s] = issue
    end
  end

  def green(text)  = "\e[32m#{text}\e[0m"
  def yellow(text) = "\e[33m#{text}\e[0m"
  def red(text)    = "\e[31m#{text}\e[0m"
end

# --- CLI ---

prd_name = ARGV[0]
command = ARGV[1] || "--status"

unless prd_name
  warn "Usage: issue-loop <prd-name> [--status|--next]"
  warn "  default: --status"
  exit 1
end

loop = IssueLoop.new(prd_name)

case command
when "--next", "-n"
  loop.next_ready
else
  loop.status
end
