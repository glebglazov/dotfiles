#!/usr/bin/env bash
# to-issues-run-one — pick the next eligible issue from index.json, run the agent
# until it completes or MAX_TRIES is exhausted.
#
# Source of truth: <issues-folder>/index.json (see the to-issues skill).
#
# Usage:   to-issues-run-one <issues-folder> [issue-file]
#          issue-file (optional) forces a specific issue instead of scanning.
#
# Env:     AGENT_CMD       default: "claude --dangerously-skip-permissions -p"
#          MAX_TRIES       default: 3
#          TRY_TIMEOUT     default: ""   (unlimited; e.g. "30m" passed to `timeout`)
#          ALLOW_DIRTY     default: unset (set to 1 to skip the clean-tree check)
#          DEFER_MANIFEST  default: unset (set to 1 to leave index.json + progress
#                          updates to the caller — used by run_all_parallel.sh)
#
# Exit:    0 = worked an issue successfully
#          1 = worked an issue but it failed (status=failed recorded)
#          2 = nothing eligible to do
#          other = preflight or unexpected failure

set -euo pipefail

AGENT_CMD=${AGENT_CMD:-"claude --dangerously-skip-permissions -p"}
MAX_TRIES=${MAX_TRIES:-3}
TRY_TIMEOUT=${TRY_TIMEOUT:-}
DEFER_MANIFEST=${DEFER_MANIFEST:-}

die() { echo "to-issues-run-one: $*" >&2; exit 3; }
LOG() { echo "[$(date '+%H:%M:%S')] to-issues-run-one: $*"; }
TS()  { date -u +%Y-%m-%dT%H:%M:%SZ; }

[[ $# -ge 1 ]] || die "usage: to-issues-run-one <issues-folder> [issue-file]"
FOLDER=$1
FORCE_ISSUE=${2:-}
[[ -d $FOLDER ]] || die "not a directory: $FOLDER"

MANIFEST="$FOLDER/index.json"
PROGRESS="$FOLDER/progress.txt"
[[ -f $MANIFEST ]] || die "manifest not found: $MANIFEST"

command -v jq  >/dev/null || die "jq not found on PATH"
command -v git >/dev/null || die "git not found on PATH"
read -r -a _agent_argv <<<"$AGENT_CMD"
command -v "${_agent_argv[0]}" >/dev/null || die "agent command not found: ${_agent_argv[0]}"

git rev-parse --show-toplevel >/dev/null 2>&1 || die "not inside a git repo"

if [[ -z ${ALLOW_DIRTY:-} ]]; then
  [[ -z $(git status --porcelain) ]] || die "working tree not clean (set ALLOW_DIRTY=1 to override)"
fi

# Eligibility query: status=="open" AND every blocked_by id resolves to a
# done issue. Missing blockers coerce to "missing" (not done) → not eligible.
ELIGIBLE_FILTER='
  .issues as $all
  | select(.status=="open")
  | select( all(.blocked_by[]?;
      . as $b
      | ([ $all[] | select(.id==$b) | .status ] | (.[0] // "missing")) == "done") )
'

if [[ -n $FORCE_ISSUE ]]; then
  NEXT_FILE=$(basename "$FORCE_ISSUE")
  ID=$(jq -r --arg f "$NEXT_FILE" '.issues[] | select(.file==$f) | .id' "$MANIFEST")
  [[ -n $ID ]] || die "issue file not in manifest: $NEXT_FILE"
else
  read -r ID NEXT_FILE < <(jq -r "
    [ .issues[] | $ELIGIBLE_FILTER ][0] // empty
    | \"\\(.id)\t\\(.file)\"
  " "$MANIFEST") || true
  if [[ -z ${ID:-} ]]; then
    LOG "no eligible issues"
    exit 2
  fi
fi

NEXT="$FOLDER/$NEXT_FILE"
[[ -f $NEXT ]] || die "issue markdown missing: $NEXT"

NUM=${ID%%-*}
NAME=${ID#*-}
ISSUE_START=$SECONDS
LOG "working $NEXT (id: $ID)"

PROMPT=$(cat <<EOF
You are implementing the issue at: $NEXT

Read the issue file in full. Read any parent or PRD it references (see the
"## Parent" section) for context. Implement the work described under
"What to build" and satisfy every box under "Acceptance criteria".

Do NOT modify $MANIFEST. Do NOT modify other issue files in $FOLDER.
Do NOT make git commits — the runner script handles state and committing.

When you have completed the work, print a summary block followed by the
completion sentinel as the final lines of your output, exactly:

SUMMARY_START
<one or more lines describing what you did>
SUMMARY_END
TASK_COMPLETE

If you cannot complete the task (blocked, unclear, missing info, repeated
failure), instead print as the final line:

TASK_FAILED: <one-line reason>
EOF
)

run_agent() {
  local out=$1
  LOG "agent starting (timeout: ${TRY_TIMEOUT:-none})..."
  if [[ -n $TRY_TIMEOUT ]]; then
    printf '%s\n' "$PROMPT" | timeout "$TRY_TIMEOUT" bash -c "$AGENT_CMD" | tee "$out"
  else
    printf '%s\n' "$PROMPT" | bash -c "$AGENT_CMD" | tee "$out"
  fi
}

extract_summary() {
  awk '/^SUMMARY_START$/{flag=1; next} /^SUMMARY_END$/{flag=0} flag' "$1"
}

manifest_set_done() {
  local tmp; tmp=$(mktemp)
  jq --arg id "$ID" '(.issues[] | select(.id==$id) | .status) = "done"' "$MANIFEST" > "$tmp" && mv "$tmp" "$MANIFEST"
}

manifest_set_failed() {
  local tmp; tmp=$(mktemp)
  jq --arg id "$ID" --argjson n "$MAX_TRIES" \
    '(.issues[] | select(.id==$id)) |= (.status = "failed" | .failed_after = $n)' \
    "$MANIFEST" > "$tmp" && mv "$tmp" "$MANIFEST"
}

LAST_FAIL_REASON=""
SUCCESS=0
for ((try=1; try<=MAX_TRIES; try++)); do
  LOG "try $try/$MAX_TRIES"
  OUT=$(mktemp)
  trap 'rm -f "$OUT"' EXIT
  run_agent "$OUT" || true
  LOG "agent finished, checking output..."
  if grep -q '^TASK_COMPLETE$' "$OUT"; then
    SUMMARY=$(extract_summary "$OUT")
    [[ -z $SUMMARY ]] && SUMMARY="(no summary provided)"
    if [[ -z $DEFER_MANIFEST ]]; then
      manifest_set_done
      {
        echo "$(TS) [$NEXT_FILE] DONE"
        echo "$SUMMARY"
        echo "---"
      } >> "$PROGRESS"
    fi
    git add -A
    git commit -m "$(cat <<MSG
[issue $NUM] $NAME

$SUMMARY
MSG
)"
    LOG "completed $ID in $((SECONDS - ISSUE_START))s"
    SUCCESS=1
    rm -f "$OUT"
    break
  else
    LAST_FAIL_REASON=$(grep -E '^TASK_FAILED:' "$OUT" | tail -n1 | sed 's/^TASK_FAILED:[[:space:]]*//' || true)
    [[ -z $LAST_FAIL_REASON ]] && LAST_FAIL_REASON="(no sentinel emitted)"
    LOG "try $try failed: $LAST_FAIL_REASON"
  fi
  rm -f "$OUT"
done

if [[ $SUCCESS -eq 1 ]]; then
  exit 0
fi

# Exhausted. In defer mode the caller records the failure; otherwise persist it.
if [[ -z $DEFER_MANIFEST ]]; then
  manifest_set_failed
  {
    echo "$(TS) [$NEXT_FILE] FAILED (after $MAX_TRIES tries)"
    echo "$LAST_FAIL_REASON"
    echo "---"
  } >> "$PROGRESS"
  git add -A
  git commit -m "[issue $NUM] $NAME — failed after $MAX_TRIES tries" || true
fi

LOG "$ID exhausted after $MAX_TRIES tries ($((SECONDS - ISSUE_START))s elapsed)"
exit 1
